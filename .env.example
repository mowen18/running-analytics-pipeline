# ──────────────────────────────────────────────────────────────────────
# Running Analytics Pipeline — environment configuration
#
# Copy this file to .env and fill in real values:
#     cp .env.example .env
# .env is gitignored and must NEVER be committed.
# ──────────────────────────────────────────────────────────────────────

# ── Strava API (Phase 0) ──────────────────────────────────────────────
# From https://www.strava.com/settings/api after registering your app.
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# OPTIONAL bootstrap value — leave empty and run `running-pipeline
# authorize` instead (recommended). Strava rotates refresh tokens on
# every refresh; the pipeline persists the newest token to the
# gitignored file .secrets/strava_tokens.json (0600 perms), which is
# authoritative from the first refresh onward. This env value is only
# consulted when that file does not exist yet.
STRAVA_REFRESH_TOKEN=

# ── Database (decision D2) ────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=running_analytics_db
POSTGRES_USER=running_user
POSTGRES_PASSWORD=

# ── Sync configuration (decisions D5, D6) ─────────────────────────────
# Earliest activity date to ingest (YYYY-MM-DD)
SYNC_START_DATE=2024-01-01
# Overlap window re-fetched on every incremental sync, in days
SYNC_OVERLAP_DAYS=14

# ── Stream ingestion (decision D15 — used from Phase 5 / Release 1.1) ─
STREAM_MIN_MOVING_MINUTES=45
STREAM_MAX_ACTIVITIES_PER_RUN=50

# ── Weather (Phase 2) ─────────────────────────────────────────────────
# Open-Meteo's historical API is free and requires NO API key.
# No weather credentials are needed; this section exists so nobody
# goes looking for a missing key later.
#
# Optional overrides (defaults shown). The budget caps HTTP requests per
# sync run, far below Open-Meteo's ~10k/day free tier; the gap controls
# when per-location date ranges are merged into one archive request.
WEATHER_REQUEST_BUDGET=500
WEATHER_BATCH_GAP_DAYS=7